{
  "manifest_version": 3,
  "name": "Schoology AI Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for Schoology assignments",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.schoology.com/*"
  ],
  "background": {
    "service_worker": "background/message-handler.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.schoology.com/*"],
      "js": [
        "content/schoology-detector.js",
        "content/ui-injector.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
