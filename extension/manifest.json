{
  "manifest_version": 3,
  "name": "TypeCloak",
  "version": "1.4.1",
  "description": "TypeCloak — invisible typing. Human results. Auto-types into Google Docs, Canvas & Blackboard with realistic speed and typos",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "debugger",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://docs.google.com/*",
    "*://*.instructure.com/*",
    "*://*.blackboard.com/*",
    "*://*.moodlecloud.com/*",
    "*://*.moodle.org/*",
    "https://api.gumroad.com/*"
  ],
  "commands": {
    "start-typing": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open TypeCloak and start typing"
    }
  },
  "background": {
    "service_worker": "background/message-handler.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://docs.google.com/document/*",
        "*://docs.google.com/presentation/*",
        "*://docs.google.com/forms/*",
        "*://*.instructure.com/*",
        "*://*.blackboard.com/*",
        "*://*.moodlecloud.com/*",
        "*://*.moodle.org/*"
      ],
      "js": [
        "content/typing-simulator.js",
        "content/ui-injector.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
